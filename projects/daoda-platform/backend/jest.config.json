{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "**/*.(t|j)s"
  ],
  "coverageDirectory": "../coverage",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/$1"
  },
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    ".*\\.module\\.ts$",
    ".*\\.controller\\.ts$",
    ".*\\.dto\\.ts$",
    ".*\\.interface\\.ts$",
    ".*\\.entity\\.ts$",
    "main.ts"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/"
  ]
}