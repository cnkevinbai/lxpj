# 环境变量配置

# 数据库
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daoda_platform?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 服务端口
PORT=4000

# Redis (可选)
REDIS_URL="redis://localhost:6379"

# 上传配置
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760