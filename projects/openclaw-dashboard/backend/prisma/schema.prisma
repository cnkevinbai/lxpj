// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 通知模型
model Notification {
  id          String   @id @default(cuid())
  type        String   // info, success, warning, error
  title       String
  message     String?
  read        Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

// 会话模型
model Session {
  id            String     @id @default(cuid())
  title         String     @default("新对话")
  agentId       String?
  summary       String?    @db.Text // 会话摘要
  lastMessageAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  messages      Message[]
  compressions  ContextCompression[]
  memories      AgentMemory[]

  @@index([agentId])
  @@index([createdAt])
}

// 消息模型
model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user, assistant, system
  content   String   @db.Text
  agentId   String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// 活动日志模型
model Activity {
  id        String   @id @default(cuid())
  type      String   // chat, task, file, system
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// 任务模型
model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      String      @default("pending")  // pending, in_progress, completed, cancelled
  priority    String      @default("medium")   // low, medium, high, critical
  assignee    String?
  dueDate     DateTime?
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assignee])
}

// 文件元数据
model FileMetadata {
  id          String           @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        BigInt
  path        String
  hash        String           @unique
  category    String           // FileCategory as string
  status      String           @default("UPLOADED") // FileStatus as string
  uploadedBy  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  chunks      DocumentChunk[]
}

// RAG 文档块
model DocumentChunk {
  id          String        @id @default(cuid())
  fileId      String
  file        FileMetadata  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  chunkIndex  Int
  content     String        @db.Text
  tokenCount  Int
  embeddingId String?       // 向量ID
  createdAt   DateTime      @default(now())
  
  @@index([fileId])
  @@index([embeddingId])
}

// RAG 索引元数据
model RAGIndex {
  id            String        @id @default(cuid())
  name          String        @unique
  documentCount Int           @default(0)
  chunkCount    Int           @default(0)
  status        String        @default("EMPTY") // IndexStatus as string
  config        Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ========== 对话增强功能模型 ==========

// Session 扩展字段：会话摘要
// 摘要将在用户离开会话时生成

// 上下文压缩历史
model ContextCompression {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summary     String   @db.Text
  startMessageId String
  endMessageId  String
  messageCount Int
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// Agent 记忆
model AgentMemory {
  id          String   @id @default(cuid())
  agentId     String?
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type        String   // short-term, long-term, preference
  key         String   // 记忆的键，用于查询
  value       String   @db.Text // 记忆的值
  metadata    Json?    // 额外元数据
  expiresAt   DateTime? // 短期记忆过期时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([sessionId])
  @@index([type])
  @@index([key])
  @@index([expiresAt])
}