        return userService;
    }
    
    public void setUserService(Object userService) {
        this.userService = userService;
    }
    
    public Object getRoleService() {
        return roleService;
    }
    
    public void setRoleService(Object roleService) {
        this.roleService = roleService;
    }
    
    public SubAccountConfig getConfig() {
        return config;
    }
    
    // ==================== 配置类 ====================
    
    public static class SubAccountConfig {
        private boolean enabled = true;
        private int maxSubAccountsPerTenant = 500;
        private String passwordPolicy = "medium";
        private int accountExpirationDays = 365;
        private boolean enableAudit = true;
        
        public boolean isEnabled() { return enabled; }
        public void setEnabled(boolean enabled) { this.enabled = enabled; }
        
        public int getMaxSubAccountsPerTenant() { return maxSubAccountsPerTenant; }
        public void setMaxSubAccountsPerTenant(int max) { this.maxSubAccountsPerTenant = max; }
        
        public String getPasswordPolicy() { return passwordPolicy; }
        public void setPasswordPolicy(String policy) { this.passwordPolicy = policy; }
        
        public int getAccountExpirationDays() { return accountExpirationDays; }
        public void setAccountExpirationDays(int days) { this.accountExpirationDays = days; }
        
        public boolean isEnableAudit() { return enableAudit; }
        public void setEnableAudit(boolean enable) { this.enableAudit = enable; }
    }
}
