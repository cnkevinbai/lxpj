    @Test
    void testGetSubAccount() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 先创建一个子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        assertTrue(createResult.isSuccess());
        
        String subAccountId = createResult.getData().getId();
        
        // 测试获取子账户
        var getResult = service.getSubAccount(subAccountId);
        assertTrue(getResult.isSuccess());
        assertEquals(subAccountId, getResult.getData().getId());
        
        service.stop();
    }
    
    @Test
    void testGetNonExistentSubAccount() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        var result = service.getSubAccount("non-existent-id");
        
        assertFalse(result.isSuccess());
