    @Test
    void testUpdateSubAccount() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        createRequest.setDisplayName("原始名称");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 更新子账户
        SubAccountUpdateRequest updateRequest = new SubAccountUpdateRequest();
        updateRequest.setDisplayName("更新后的名称");
        updateRequest.setEmail("updated@example.com");
        updateRequest.setMaxDevices(20);
        
        var updateResult = service.updateSubAccount(subAccountId, updateRequest);
        assertTrue(updateResult.isSuccess());
        
        // 验证更新
        SubAccountEntity updated = updateResult.getData();
        assertEquals("更新后的名称", updated.getDisplayName());
        assertEquals("updated@example.com", updated.getEmail());
        assertEquals(20, updated.getMaxDevices());
        
        service.stop();
    }
    
    @Test
    void testDeleteSubAccount() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 删除子账户
        var deleteResult = service.deleteSubAccount(subAccountId);
        assertTrue(deleteResult.isSuccess());
        
        // 验证已删除
        var getResult = service.getSubAccount(subAccountId);
        assertFalse(getResult.isSuccess());
        
        service.stop();
    }
    
    @Test
    void testEnableDisableSubAccount() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 禁用账户
        var disableResult = service.disableSubAccount(subAccountId);
        assertTrue(disableResult.isSuccess());
        
        // 验证已禁用
        var getDisabledResult = service.getSubAccount(subAccountId);
        assertTrue(getDisabledResult.isSuccess());
        assertEquals(AccountStatus.DISABLED, getDisabledResult.getData().getStatus());
        
        // 启用账户
        var enableResult = service.enableSubAccount(subAccountId);
        assertTrue(enableResult.isSuccess());
        
        // 验证已启用
        var getEnabledResult = service.getSubAccount(subAccountId);
        assertTrue(getEnabledResult.isSuccess());
        assertEquals(AccountStatus.ACTIVE, getEnabledResult.getData().getStatus());
        
        service.stop();
    }
    
    @Test
    void testResetPassword() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("OldPassword123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        String oldPasswordHash = createResult.getData().getPasswordHash();
        
        // 重置密码
        var resetResult = service.resetPassword(subAccountId, "NewPassword456!");
        assertTrue(resetResult.isSuccess());
        
        // 验证密码已更新
        var getResult = service.getSubAccount(subAccountId);
        assertNotEquals(oldPasswordHash, getResult.getData().getPasswordHash());
        assertNotNull(getResult.getData().getPasswordResetAt());
        
        service.stop();
    }
    
