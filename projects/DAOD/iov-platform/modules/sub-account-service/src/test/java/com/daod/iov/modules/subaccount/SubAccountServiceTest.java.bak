package com.daod.iov.modules.subaccount;

import com.daod.iov.plugin.ModuleContext;
import com.daod.iov.plugin.ModuleException;
import org.junit.jupiter.api.*;
import static org.junit.jupiter.api.Assertions.*;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import java.time.LocalDateTime;
import java.util.*;

/**
 * 子账户服务测试类
 */
class SubAccountServiceTest {
    
    private SubAccountService service;
    private AutoCloseable closeable;
    
    @Mock
    private ModuleContext context;
    
    @BeforeEach
    void setUp() {
        closeable = MockitoAnnotations.openMocks(this);
        service = new SubAccountService();
    }
    
    @AfterEach
    void tearDown() throws Exception {
        if (closeable != null) {
            closeable.close();
        }
    }
    
    @Test
    void testModuleMetadata() {
        assertNotNull(service.getMetadata());
        assertEquals("sub-account-service", service.getMetadata().getName());
        assertEquals("1.0.0", service.getMetadata().getVersion());
        assertEquals("business", service.getMetadata().getType());
        assertEquals(55, service.getMetadata().getPriority());
    }
    
    @Test
    void testModuleLifecycle() throws ModuleException {
        // 创建模拟上下文
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        
        // 测试初始状态
        assertEquals(ModuleState.UNINITIALIZED, service.getState());
        assertEquals(HealthStatus.UNKNOWN, service.getHealthStatus());
        
        // 测试初始化
        service.initialize(context);
        assertEquals(ModuleState.INITIALIZED, service.getState());
        assertEquals(HealthStatus.HEALTHY, service.getHealthStatus());
        
        // 测试启动
        service.start();
        assertEquals(ModuleState.RUNNING, service.getState());
        assertEquals(HealthStatus.HEALTHY, service.getHealthStatus());
        
        // 测试停止
        service.stop();
        assertEquals(ModuleState.STOPPED, service.getState());
        assertEquals(HealthStatus.OFFLINE, service.getHealthStatus());
        
        // 测试销毁
        service.destroy();
        assertEquals(ModuleState.DESTROYED, service.getState());
    }
    
    @Test
    void testCreateSubAccount() throws ModuleException {
        // 初始化服务
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建创建请求
        SubAccountCreateRequest request = new SubAccountCreateRequest();
        request.setParentAccountId("parent-001");
        request.setUsername("subuser001");
        request.setDisplayName("子用户001");
        request.setEmail("subuser001@example.com");
        request.setPassword("Password123!");
        request.setMaxDevices(10);
        request.setMaxLocations(50);
        
        // 调用创建方法
        var result = service.createSubAccount(request);
        
        assertTrue(result.isSuccess());
        assertNotNull(result.getData());
        
        // 验证创建的子账户
        SubAccountEntity subAccount = result.getData();
        assertEquals("parent-001", subAccount.getParentAccountId());
        assertEquals("subuser001", subAccount.getUsername());
        assertEquals("子用户001", subAccount.getDisplayName());
        assertEquals("subuser001@example.com", subAccount.getEmail());
        assertEquals(AccountStatus.ACTIVE, subAccount.getStatus());
        assertTrue(subAccount.getPasswordHash().startsWith("ENC:"));
        assertNotNull(subAccount.getCreatedAt());
        assertNotNull(subAccount.getExpiresAt());
        
        service.stop();
    }
    
    @Test
    void testCreateSubAccountWithMissingParentId() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
