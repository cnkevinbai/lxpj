    @Test
    void testListSubAccounts() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建多个子账户
        for (int i = 0; i < 5; i++) {
            SubAccountCreateRequest request = new SubAccountCreateRequest();
            request.setParentAccountId("parent-001");
            request.setUsername("subuser" + i);
            request.setPassword("Password123!");
            service.createSubAccount(request);
        }
        
        // 分页查询
        var result = service.listSubAccounts("parent-001", 1, 3);
        assertTrue(result.isSuccess());
        
        var pageResult = result.getData();
        assertNotNull(pageResult);
        assertEquals(5, pageResult.getTotal());
        assertEquals(3, pageResult.getSize());
        assertEquals(1, pageResult.getPage());
        assertEquals(3, pageResult.getRecords().size());
        
        service.stop();
    }
    
    @Test
    void testCheckAccountExpired() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户（设置过期时间）
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 检查是否过期（应该未过期）
        var checkResult = service.checkAccountExpired(subAccountId);
        assertTrue(checkResult.isSuccess());
        assertFalse(checkResult.getData());
        
        service.stop();
    }
    
    @Test
    void testGetQuotaInfo() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        createRequest.setMaxDevices(10);
        createRequest.setMaxLocations(50);
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 查询配额
        var result = service.getQuotaInfo(subAccountId);
        assertTrue(result.isSuccess());
        
        QuotaInfo quotaInfo = result.getData();
        assertEquals(10, quotaInfo.getMaxDevices());
        assertEquals(50, quotaInfo.getMaxLocations());
        assertEquals(0, quotaInfo.getDevicesUsed());
        assertEquals(0, quotaInfo.getLocationsUsed());
        
        service.stop();
    }
    
    @Test
    void testGetLoginLogs() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 获取登录日志
        var result = service.getLoginLogs(subAccountId, 1, 10);
        assertTrue(result.isSuccess());
        
        var pageResult = result.getData();
        assertNotNull(pageResult);
        assertEquals(0, pageResult.getTotal()); // 初始没有日志
        assertEquals(10, pageResult.getSize());
        
        service.stop();
    }
    
    @Test
    void testGetSubAccountOfDisabled() throws ModuleException {
        ModuleContext context = new ModuleContext("sub-account-service:1.0.0", "", null);
        service.initialize(context);
        service.start();
        
        // 创建子账户
        SubAccountCreateRequest createRequest = new SubAccountCreateRequest();
        createRequest.setParentAccountId("parent-001");
        createRequest.setUsername("subuser001");
        createRequest.setPassword("Password123!");
        
        var createResult = service.createSubAccount(createRequest);
        String subAccountId = createResult.getData().getId();
        
        // 禁用账户
        service.disableSubAccount(subAccountId);
        
        // 获取禁用的账户
        var result = service.getSubAccount(subAccountId);
        assertFalse(result.isSuccess());
        assertTrue(result.getMessage().contains("账户状态异常"));
        
        service.stop();
    }
}
